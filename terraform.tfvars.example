# Example Terraform Variables for OpenClaw Deployment
# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to version control!

# General Configuration
aws_region   = "us-east-1"  # Change to your preferred region
environment  = "production"
project_name = "openclaw"
team_name    = "startup-team"

# Instance Configuration
instance_type      = "t4g.small"  # ARM64, 2 vCPU, 2GB RAM, ~$12/month
root_volume_size   = 20           # GB for OS and Docker images
data_volume_size   = 30           # GB for OpenClaw data persistence

# Networking Configuration
use_existing_vpc   = false         # Set to true if using existing VPC
existing_vpc_id    = ""            # Fill if use_existing_vpc = true
existing_subnet_id = ""            # Fill if use_existing_vpc = true
vpc_cidr           = "10.0.0.0/16"
subnet_cidr        = "10.0.1.0/24"

# Security Configuration
# IMPORTANT: Replace 0.0.0.0/0 with your office/home IP for security!
# Get your IP: curl ifconfig.me
allowed_ssh_cidrs = [
  "0.0.0.0/0"  # CHANGE THIS! Example: "203.0.113.0/24"
]

# Enable HTTPS if setting up reverse proxy with domain
enable_https = false

# Allocate static Elastic IP (recommended for production)
allocate_elastic_ip = false  # Set to true for static IP

# SSH Key Configuration
# Option 1: Create new key pair (recommended)
create_new_key_pair = true
ssh_public_key      = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAACAQC... your-email@example.com"

# Option 2: Use existing key pair
# create_new_key_pair = false
# existing_key_name   = "my-existing-key"

# OpenClaw Configuration
openclaw_repo_url = "https://github.com/openclaw/openclaw.git"

# AI Provider API Keys
# Get keys from:
# - Anthropic: https://console.anthropic.com/
# - OpenAI: https://platform.openai.com/api-keys
anthropic_api_key = ""  # Optional: Your Anthropic API key
openai_api_key    = ""  # Optional: Your OpenAI API key

# Channel Integration Tokens
# Get tokens from:
# - Telegram: @BotFather on Telegram
# - Discord: https://discord.com/developers/applications
telegram_bot_token = ""  # Optional: Your Telegram bot token
discord_bot_token  = ""  # Optional: Your Discord bot token

# Tailscale VPN Configuration (recommended for team access)
# Get auth key from: https://login.tailscale.com/admin/settings/keys
enable_tailscale   = true
tailscale_auth_key = ""  # Optional: Tailscale one-time or reusable auth key

# Monitoring Configuration
log_retention_days = 7  # CloudWatch log retention (1, 3, 7, 14, 30, etc.)
